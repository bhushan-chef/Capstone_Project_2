<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Capstone Automation Suite" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="com.expandtesting.utils.RetryListener"/>
        <listener class-name="com.expandtesting.utils.ScreenshotListener"/>
    </listeners>

    <test name="UI Tests">
        <packages>
            <package name="com.expandtesting.tests.ui"/>
        </packages>
    </test>

    <test name="API Tests">
        <packages>
            <package name="com.expandtesting.tests.api"/>
        </packages>
    </test>

    <test name="E2E Hybrid Tests">
        <packages>
            <package name="com.expandtesting.tests.e2e"/>
        </packages>
    </test>

</suite>